# Auto-load .env.local when entering the project directory.
# Run `direnv allow` once after editing this file.
dotenv_if_exists .env.local
dotenv_if_exists .env.development

# Use the Node/pnpm versions pinned in mise.toml (if mise is installed).
use mise 2>/dev/null || true

# Convenience PATH for project-local binaries.
PATH_add node_modules/.bin
